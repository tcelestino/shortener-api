generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Short {
  id          Int      @id @default(autoincrement())
  url         String
  shortCode   String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  accessCount Int      @default(0)
}
